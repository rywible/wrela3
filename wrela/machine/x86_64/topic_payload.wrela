module machine.x86_64.topic_payload

data TimerTickPayload {
    sequence: U64
    monotonic_us: U64
    source_id: U32
}

static_assert(sizeof(TimerTickPayload) <= 64, message = "timer tick payload fits one topic slot")
static_assert(alignof(TimerTickPayload) == 8, message = "timer tick payload alignment")
