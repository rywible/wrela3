module tests.e2e.cache_memory

use { DelegatedHardware } from platform.uefi.transition
use { BootPanic } from platform.hardware.panic
use { PlatformDiscoveryRoot } from platform.hardware.discovery
use { CacheArena } from machine.x86_64.cache_memory
use { ClaimedPciPlanBuilder, CpuPlan, DriverMemory, ExecutorSlot, HardwarePlan, InterruptRoutingPlan, IoPortAuthority, OwnedHardware, OwnedMemory, MemoryPlan, SlotIdentity } from machine.x86_64.cpu_state
use { Bytes, ExecutorMemory } from machine.x86_64.executor_memory
use { InterruptVector } from machine.x86_64.interrupts
use { SerialDriver, SerialWriterRegisters, SerialWritePath } from machine.x86_64.serial

executor CacheMemoryProbe {
    slot: ExecutorSlot
    memory: ExecutorMemory
    serial_path: SerialWritePath
    cache: CacheArena
    zero_cache: CacheArena
    short_cache: CacheArena

    start fn run(self) -> never {
        with self.memory.frame(length = 4096) as empty_frame {
            let empty = self.cache.get_bytes(key = 0, into = empty_frame)
            if empty.hit {
                self.serial_path.write(self.memory.bytes(value = "empty cache hit\n"))
            }
        }

        let first_put = self.cache.put_bytes(key = 1, bytes = self.memory.bytes(value = "old cache\n"))
        let second_put = self.cache.put_bytes(key = 2, bytes = self.memory.bytes(value = "cache memory ok\n"))

        with self.memory.frame(length = 4096) as lookup_frame {
            let evicted = self.cache.get_bytes(key = 1, into = lookup_frame)
            let cached = self.cache.get_bytes(key = 2, into = lookup_frame)
            if first_put.stored == false {
                self.serial_path.write(self.memory.bytes(value = "first put failed\n"))
            }
            if second_put.stored == false {
                self.serial_path.write(self.memory.bytes(value = "second put failed\n"))
            }
            if first_put.evicted != 0 {
                self.serial_path.write(self.memory.bytes(value = "first put evicted\n"))
            }
            if second_put.evicted == 0 {
                self.serial_path.write(self.memory.bytes(value = "second put missed eviction\n"))
            }
            if evicted.hit {
                self.serial_path.write(self.memory.bytes(value = "stale cache\n"))
            }
            if cached.hit {
                self.serial_path.write(cached.bytes)
            }
        }
        let empty_value_put = self.cache.put_bytes(key = 0, bytes = self.memory.bytes(value = ""))
        with self.memory.frame(length = 4096) as empty_value_frame {
            let empty_value = self.cache.get_bytes(key = 0, into = empty_value_frame)
            if empty_value_put.stored == false {
                self.serial_path.write(self.memory.bytes(value = "empty value put failed\n"))
            }
            if empty_value.hit == false {
                self.serial_path.write(self.memory.bytes(value = "empty value missed\n"))
            }
        }
        self.zero_cache.clear()
        let zero_slot_put = self.zero_cache.put_bytes(key = 7, bytes = self.memory.bytes(value = "zero slot\n"))
        with self.memory.frame(length = 4096) as zero_slot_frame {
            let zero_slot_lookup = self.zero_cache.get_bytes(key = 7, into = zero_slot_frame)
            if zero_slot_put.stored {
                self.serial_path.write(self.memory.bytes(value = "zero slot stored\n"))
            }
            if zero_slot_lookup.hit {
                self.serial_path.write(self.memory.bytes(value = "zero slot hit\n"))
            }
        }
        self.short_cache.clear()
        let short_cache_put = self.short_cache.put_bytes(key = 9, bytes = self.memory.bytes(value = "short cache\n"))
        with self.memory.frame(length = 4096) as short_cache_frame {
            let short_cache_lookup = self.short_cache.get_bytes(key = 9, into = short_cache_frame)
            if short_cache_put.stored {
                self.serial_path.write(self.memory.bytes(value = "short cache stored\n"))
            }
            if short_cache_lookup.hit {
                self.serial_path.write(self.memory.bytes(value = "short cache hit\n"))
            }
        }
        self.memory.halt_forever()
    }
}

image CacheMemorySmoke {
    transitions {
        delegated_hardware -> owned_hardware
    }

    phase delegated_hardware(hardware: DelegatedHardware) -> OwnedHardware {
        let root = PlatformDiscoveryRoot(panic = BootPanic())
        let discovery = root.from_uefi(hardware = hardware)
        let memory_region = discovery.memory.require_usable_region(
            min_base = 0x200000,
            length = 0x400000,
            align = 4096
        )
        let hardware_plan = HardwarePlan(
            cpus = discovery.acpi.require_madt().enabled_cpus().require_count(count = 2),
            interrupts = InterruptRoutingPlan(
                local_apic = discovery.interrupts.local_apic,
                serial_irq4 = discovery.interrupts.route_isa_irq(irq = 4, vector = InterruptVector(value = 0x40))
            ),
            pci = ClaimedPciPlanBuilder(panic = discovery.panic).empty()
        )
        let memory_plan = MemoryPlan(
            owned_memory = OwnedMemory(arena = memory_region),
            executor_arena = memory_region,
            io_ports = IoPortAuthority()
        )
        let cpu_plan = CpuPlan(
            owned_stack_top = memory_region.address + memory_region.length,
            gdt_descriptor = Bytes(address = 0, length = 0),
            idt_descriptor = Bytes(address = 0, length = 0),
            cr3 = memory_region.address
        )
        return hardware.exit_to_owned_hardware(
            memory_plan = memory_plan,
            cpu_plan = cpu_plan,
            hardware_plan = hardware_plan
        )
    }

    phase owned_hardware(hardware: OwnedHardware) -> never {
        let com1 = hardware.io_ports.claim_com1()
        let registers = SerialWriterRegisters(port_base = com1.port_base)
        let serial_driver = SerialDriver(
            registers = registers,
            memory = DriverMemory(region = hardware.memory.arena)
            ).initialize()
        let serial_path = SerialWritePath(registers = serial_driver.registers)
        let slot = hardware.executors.claim(identity = SlotIdentity(label = "cache"))
        let executor_memory = hardware.memory.claim_executor_arena(owner = slot, length = 0x200000, align = 4096)
        serial_path.write(executor_memory.bytes(value = "discovery: memory=selected lapic=selected ioapic=selected pci=selected\n"))
        let storage = executor_memory.reserve(length = 40, align = 8)
        let zero_storage = executor_memory.reserve(length = 24, align = 8)
        let short_storage = executor_memory.reserve(length = 39, align = 8)
        let cache = CacheArena(
            storage = storage,
            slot_count = 1,
            slot_size = 16,
            next_victim = 0,
            initialized = 0
        )
        let zero_cache = CacheArena(
            storage = zero_storage,
            slot_count = 0,
            slot_size = 16,
            next_victim = 0,
            initialized = 0
        )
        let short_cache = CacheArena(
            storage = short_storage,
            slot_count = 1,
            slot_size = 16,
            next_victim = 0,
            initialized = 0
        )
        cache.clear()
        let probe = CacheMemoryProbe(
            slot = slot,
            memory = executor_memory,
            serial_path = serial_path,
            cache = cache,
            zero_cache = zero_cache,
            short_cache = short_cache
        )
        hardware.vcpu0.enter(executor = probe)
    }
}
