module tests.e2e.fixtures.hello_ivshmem.program

use { Option } from wrela.lang.core
use { ExecutorSlot } from machine.x86_64.executor_slot
use { EventSleepPolicy } from machine.x86_64.executor_loop
use { Bytes, ExecutorMemory } from machine.x86_64.executor_memory
use { EduInterrupt, EduMsiPath } from machine.x86_64.edu
use { ApicInterruptController, InterruptVector } from machine.x86_64.interrupts
use { IvshmemDoorbellInterrupt, IvshmemDoorbellPath, IvshmemDoorbellPeerPath } from machine.x86_64.ivshmem
use { MsiCapability, MsixCapability } from machine.x86_64.pci
use { SerialConsolePath } from machine.x86_64.serial
use { TopicSubscription } from machine.x86_64.topic
use { SerialPathInterrupt } from machine.x86_64.topic_payload

data RunScratch {
    hello: Bytes
}

executor HelloWorld {
    slot: ExecutorSlot
    loop: EventSleepPolicy
    memory: ExecutorMemory
    interrupts: ApicInterruptController
    edu_msi: MsiCapability
    ivshmem_msix: MsixCapability
    serial_path: SerialConsolePath
    serial_rx: TopicSubscription<SerialPathInterrupt>
    edu_path: EduMsiPath
    edu_interrupts: TopicSubscription<EduInterrupt>
    ivshmem_rx: IvshmemDoorbellPath
    ivshmem_events: TopicSubscription<IvshmemDoorbellInterrupt>
    ivshmem_tx: IvshmemDoorbellPeerPath

    start fn run(self) -> never {
        with self.memory.frame(length = 4096) as tick {
            let scratch = tick.place(RunScratch(hello = self.memory.bytes(value = "hello from wrela\n")))
            self.serial_path.write(scratch.hello)
        }
        self.interrupts.initialize_for_com1_receive()
        self.edu_msi.route(vector = InterruptVector(value = 0x41), target = self.interrupts.local_apic)
        self.ivshmem_msix.route_entry(entry = 0, vector = InterruptVector(value = 0x42), target = self.interrupts.local_apic)
        self.interrupts.enable_cpu_interrupts()
        self.edu_path.raise_test_interrupt()
        self.ivshmem_tx.ring_peer(peer_id = self.ivshmem_rx.position(), vector = 0)
        while true {
            match self.serial_rx.try_next() {
                Option.Some(value = serial_event) => {
                    if serial_event.has_byte {
                        self.serial_path.write(self.memory.bytes(value = "serial interrupt: "))
                        self.serial_path.write_byte(value = serial_event.byte)
                        self.serial_path.write(self.memory.bytes(value = "\n"))
                        self.serial_path.ack_receive(event = serial_event)
                    }
                }
                Option.None => {
                    self.serial_rx.arm_wait()
                }
            }
            match self.edu_interrupts.try_next() {
                Option.Some(value = edu_event) => {
                    self.serial_path.write(self.memory.bytes(value = "msi interrupt\n"))
                    self.edu_path.ack_completed(event = edu_event)
                }
                Option.None => {
                    self.edu_interrupts.arm_wait()
                }
            }
            match self.ivshmem_events.try_next() {
                Option.Some(value = ivshmem_event) => {
                    self.serial_path.write(self.memory.bytes(value = "msix interrupt\n"))
                    self.ivshmem_rx.ack_doorbell(event = ivshmem_event)
                }
                Option.None => {
                    self.ivshmem_events.arm_wait()
                }
            }

            self.serial_rx.arm_wait()
            self.edu_interrupts.arm_wait()
            self.ivshmem_events.arm_wait()

            let had_retry_event = false
            if let Option.Some(value = serial_retry) = self.serial_rx.try_next() {
                had_retry_event = true
                if serial_retry.has_byte {
                    self.serial_path.write(self.memory.bytes(value = "serial interrupt: "))
                    self.serial_path.write_byte(value = serial_retry.byte)
                    self.serial_path.write(self.memory.bytes(value = "\n"))
                    self.serial_path.ack_receive(event = serial_retry)
                }
            }
            if let Option.Some(value = edu_retry) = self.edu_interrupts.try_next() {
                had_retry_event = true
                self.serial_path.write(self.memory.bytes(value = "msi interrupt\n"))
                self.edu_path.ack_completed(event = edu_retry)
            }
            if let Option.Some(value = ivshmem_retry) = self.ivshmem_events.try_next() {
                had_retry_event = true
                self.serial_path.write(self.memory.bytes(value = "msix interrupt\n"))
                self.ivshmem_rx.ack_doorbell(event = ivshmem_retry)
            }
            if had_retry_event == false {
                if self.serial_rx.is_wait_armed() {
                    if self.edu_interrupts.is_wait_armed() {
                        if self.ivshmem_events.is_wait_armed() {
                            self.loop.wait()
                        }
                    }
                }
            }
        }
    }
}
